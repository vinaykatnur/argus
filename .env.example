# General Properties
SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Database Configuration (e.g., Aiven MySQL)
MYSQL_URL=jdbc:mysql://<aiven-mysql-host>:<port>/<database-name>?useSSL=true&requireSSL=true&allowPublicKeyRetrieval=true&serverTimezone=UTC
MYSQL_USERNAME=<mysql-username>
MYSQL_PASSWORD=<mysql-password>
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Security Configuration
JWT_SECRET=<secure-random-key-at-least-32-characters>
JWT_ISSUER=argus

# SMTP Email Configuration (Optional)
REQUIRE_EMAIL_VERIFICATION=false
MAIL_HOST=<smtp-host>
MAIL_PORT=587
MAIL_USERNAME=<smtp-username>
MAIL_PASSWORD=<smtp-password>

# Cross-Origin Resource Sharing (CORS) & Base URLs
FRONTEND_BASE_URL=https://<your-vercel-domain>.vercel.app
CORS_ALLOWED_ORIGINS=https://<your-vercel-domain>.vercel.app

# Incident Intelligence (AI) Setup
AI_CREDENTIAL_ENCRYPTION_SECRET=<secure-encryption-secret-key>
